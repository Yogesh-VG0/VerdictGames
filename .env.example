# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# External APIs
RAWG_API_KEY=your-rawg-api-key

# Steam (optional — enables player counts, news, achievements)
STEAM_API_KEY=your-steam-api-key

# IGDB / Twitch (optional — enables IGDB enrichment)
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# Database (for migration scripts only)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Site URL
NEXT_PUBLIC_SITE_URL=https://www.verdict.games

# Cron/ingest endpoint protection (required in production)
CRON_SECRET=generate-a-random-secret
